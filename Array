Is array sorted in Non-decreasing order

Sol. bool isSorted(vector<int>& arr) {
        // code here
        int n=arr.size();
        for(int i=0;i<n-1;i++){
            if(arr[i+1]<arr[i])return false;
        }
        return true;
    }

Remove Duplicates

Sol. 
int removeDuplicates(vector<int>& nums) {
        int count=1;
        int n=nums.size();
        for(int i=0;i<n-1;i++){
            if(nums[i]!=nums[i+1]){
                nums[count]=nums[i+1];
                count++;
            }
        }
        return count;
    }
